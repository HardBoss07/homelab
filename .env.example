# ========================================================
# CLOUDFLARE & TRAEFIK INFRASTRUCTURE
# ========================================================
CLOUDFLARE_EMAIL=your-email@example.com
CLOUDFLARE_API_KEY=your-global-api-key
CLOUDFLARE_ZONE_ID=your-zone-id
CF_TUNNEL_TOKEN=your-tunnel-token
DOMAIN=m4tt3o.dev
TZ=Europe/Berlin

# ========================================================
# STORABLE: DATABASE CONFIGURATION
# ========================================================
# Root password for MySQL initialization
MYSQL_ROOT_PASSWORD=password
MYSQL_DATABASE=storable

# Application credentials for the backend to connect to MySQL
# Note: SPRING_DATASOURCE_URL uses 'storable_db' because that is the service name
DB_USER=backend_user
DB_PASS=backend_password
SPRING_DATASOURCE_URL=jdbc:mysql://storable_db:3306/storable?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=${MYSQL_ROOT_PASSWORD}

# ========================================================
# STORABLE: BACKEND CONFIGURATION
# ========================================================
SERVER_PORT=8080
MAX_FILE_SIZE=5GB
MAX_REQUEST_SIZE=5GB
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_HIBERNATE_DDL_AUTO=none
STORABLE_STORAGE_UPLOAD_DIR=/app/storage

# Auth Settings
STORABLE_AUTH_GUEST_USER_ID=00000000-0000-0000-0000-000000000000
STORABLE_AUTH_GUEST_MODE_ENABLED=true

# ========================================================
# STORABLE: FRONTEND CONFIGURATION
# ========================================================
# The public URL the browser uses to talk to the API
NEXT_PUBLIC_API_URL=https://api-storable.m4tt3o.dev

# ========================================================
# HOST PORT MAPPING (Optional for local debugging)
# ========================================================
HOST_PORT_BACKEND=8080
HOST_PORT_FRONTEND=3000
HOST_PORT_DB=3306